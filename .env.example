# Hermeneia environment example
HERMENEIA_ENV=development
HERMENEIA_DATABASE_PATH=./data/hermeneia.sqlite

# Optional future OpenAI configuration.
# The current CLI MVP does not require these values. Set both OPENAI_API_KEY and
# OPENAI_MODEL to enable `hermeneia research --planner openai`.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
